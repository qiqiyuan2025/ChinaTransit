---
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { type Locale, locales } from '../i18n/translations';
import { getTranslations, getLocalePath, getLocaleFromUrl, getPathWithoutLocale } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
}

const locale: Locale = Astro.props.locale ?? getLocaleFromUrl(Astro.url);
const t = getTranslations(locale);
const { title, description = t.meta.defaultDescription } = Astro.props;

const siteUrl = 'https://chinatransit.info';
const basePath = getPathWithoutLocale(Astro.url);
const canonicalPath = getLocalePath(basePath, locale);
const canonicalUrl = `${siteUrl}${canonicalPath}${canonicalPath.endsWith('/') ? '' : '/'}`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="msvalidate.01" content="6F3163B0F1148152930309CC0CC7F1B4" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang alternates -->
    {locales.map((loc) => {
      const altPath = getLocalePath(basePath, loc);
      const altUrl = `${siteUrl}${altPath}${altPath.endsWith('/') ? '' : '/'}`;
      return <link rel="alternate" hreflang={loc} href={altUrl} />;
    })}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${getLocalePath(basePath, 'en')}${getLocalePath(basePath, 'en').endsWith('/') ? '' : '/'}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="ChinaTransit" />
    <meta property="og:locale" content={locale === 'en' ? 'en_US' : locale === 'ja' ? 'ja_JP' : locale === 'ko' ? 'ko_KR' : 'fr_FR'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "ChinaTransit",
      "url": siteUrl,
      "description": t.meta.defaultDescription,
      "inLanguage": locales,
    })} />
  </head>
  <body class="bg-paper-50 text-ink min-h-screen">
    <nav class="border-b border-paper-300 bg-paper-50/80 backdrop-blur-sm sticky top-0 z-50">
      <div class="max-w-reading mx-auto px-4 py-3 flex items-center justify-between">
        <a href={getLocalePath('/', locale)} class="font-display text-xl font-bold text-ink hover:text-mineral transition-colors">
          ChinaTransit
        </a>
        <div class="flex items-center gap-4 text-sm">
          <a href={getLocalePath('/check', locale)} class="text-ink-light hover:text-mineral transition-colors">{t.nav.visaCheck}</a>
          <a href={getLocalePath('/pay', locale)} class="text-ink-light hover:text-mineral transition-colors">{t.nav.payments}</a>
          <a href={getLocalePath('/esim', locale)} class="text-ink-light hover:text-mineral transition-colors">{t.nav.esim}</a>
          <a href={getLocalePath('/apps', locale)} class="text-ink-light hover:text-mineral transition-colors">{t.nav.apps}</a>
          <LanguageSwitcher locale={locale} />
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="border-t border-paper-300 mt-16">
      <div class="max-w-reading mx-auto px-4 py-8 text-center text-sm text-ink-light">
        <p>{t.footer.disclaimer}</p>
        <p class="mt-2 font-chinese text-xs">{t.footer.disclaimerLocal}</p>
      </div>
    </footer>
  </body>
</html>
