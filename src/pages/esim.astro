---
import Layout from '../layouts/Layout.astro';
---

<Layout title="eSIM Guide — ChinaTransit">
  <div class="max-w-reading mx-auto px-4 py-12">
    <div class="text-center mb-10">
      <p class="font-chinese text-ink-light text-sm mb-2">电话卡与上网指南</p>
      <h1 class="font-display text-4xl font-bold text-ink">eSIM & Connectivity</h1>
      <p class="text-ink-light mt-2">Stay connected from the moment you land.</p>
    </div>

    <div class="space-y-8">
      <!-- Option 1: eSIM -->
      <div class="p-6 bg-paper-100 rounded-xl border border-paper-300">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-mineral/10 rounded-lg flex items-center justify-center text-mineral text-xl shrink-0">
            📶
          </div>
          <div>
            <h2 class="font-display text-2xl font-semibold mb-2">eSIM (Recommended)</h2>
            <p class="text-ink-light text-sm mb-4">
              Buy before you fly. Activates instantly when you land. No physical SIM swap needed.
            </p>
            <div class="space-y-3">
              <div class="p-3 bg-paper-50 rounded-lg border border-paper-300">
                <h3 class="font-semibold text-sm mb-1">Airalo</h3>
                <p class="text-sm text-ink-light">
                  Most popular for travelers. China plans from ~$5/1GB. Buy in the app, scan QR code, activate on arrival.
                  Data-only (no Chinese phone number).
                </p>
              </div>
              <div class="p-3 bg-paper-50 rounded-lg border border-paper-300">
                <h3 class="font-semibold text-sm mb-1">Nomad / Holafly</h3>
                <p class="text-sm text-ink-light">
                  Unlimited data plans available. Good if you plan to stream or use maps heavily. Slightly pricier.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Option 2: Airport SIM -->
      <div class="p-6 bg-paper-100 rounded-xl border border-paper-300">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-mineral/10 rounded-lg flex items-center justify-center text-mineral text-xl shrink-0">
            🏪
          </div>
          <div>
            <h2 class="font-display text-2xl font-semibold mb-2">Airport SIM Card</h2>
            <p class="text-ink-light text-sm mb-4">
              Available at China Mobile / China Unicom counters in most international terminals.
            </p>
            <ul class="space-y-2 text-sm">
              <li class="flex gap-2">
                <span class="text-jade shrink-0">✓</span>
                <span>Gives you a Chinese phone number (needed for some app registrations)</span>
              </li>
              <li class="flex gap-2">
                <span class="text-jade shrink-0">✓</span>
                <span>Staff will help you set it up</span>
              </li>
              <li class="flex gap-2">
                <span class="text-cinnabar shrink-0">✗</span>
                <span>Requires passport registration (takes 10-15 minutes)</span>
              </li>
              <li class="flex gap-2">
                <span class="text-cinnabar shrink-0">✗</span>
                <span>May not be available late at night</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- VPN note -->
      <div class="p-4 bg-amber/10 rounded-lg border border-amber">
        <h3 class="font-semibold text-sm mb-2">About VPNs</h3>
        <p class="text-sm text-ink-light">
          Google, Instagram, WhatsApp, and many Western apps don't work in China without a VPN.
          Some eSIM providers include VPN or tunnel through servers outside China. Check your provider's policy.
          Download and test your VPN <strong>before</strong> arriving — you can't download most VPN apps from within China.
        </p>
      </div>

      <!-- Quick comparison -->
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b border-paper-300">
              <th class="text-left p-3 font-semibold">Feature</th>
              <th class="text-center p-3 font-semibold">eSIM</th>
              <th class="text-center p-3 font-semibold">Airport SIM</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-paper-200">
              <td class="p-3 text-ink-light">Setup time</td>
              <td class="p-3 text-center">Instant</td>
              <td class="p-3 text-center">10-15 min</td>
            </tr>
            <tr class="border-b border-paper-200">
              <td class="p-3 text-ink-light">Chinese phone number</td>
              <td class="p-3 text-center">No</td>
              <td class="p-3 text-center">Yes</td>
            </tr>
            <tr class="border-b border-paper-200">
              <td class="p-3 text-ink-light">Buy before travel</td>
              <td class="p-3 text-center">Yes</td>
              <td class="p-3 text-center">No</td>
            </tr>
            <tr class="border-b border-paper-200">
              <td class="p-3 text-ink-light">Cost (7-day)</td>
              <td class="p-3 text-center">$5-15</td>
              <td class="p-3 text-center">¥50-100</td>
            </tr>
            <tr>
              <td class="p-3 text-ink-light">VPN included</td>
              <td class="p-3 text-center">Sometimes</td>
              <td class="p-3 text-center">No</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>
