---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ChinaTransit — Is China on your way?">
  <section class="max-w-reading mx-auto px-4 py-16 text-center">
    <p class="font-chinese text-ink-light text-sm mb-4">中国过境免签 240 小时</p>
    <h1 class="font-display text-5xl md:text-6xl font-bold text-ink mb-6">
      Is China on your way?
    </h1>
    <p class="text-lg text-ink-light max-w-md mx-auto mb-10">
      Check if you qualify for China's 240-hour visa-free transit.
      Get your payments, eSIM, and apps sorted before you land.
    </p>

    <a
      href="/check"
      class="inline-block bg-mineral text-paper-50 px-8 py-3 rounded-lg font-semibold text-lg hover:bg-mineral-light transition-colors"
    >
      Check My Eligibility
    </a>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-20 text-left">
      <div class="p-6 bg-paper-100 rounded-lg border border-paper-300">
        <div class="text-2xl mb-3">🛂</div>
        <h3 class="font-display text-xl font-semibold mb-2">Visa Checker</h3>
        <p class="text-ink-light text-sm">
          Enter your nationality and route. Get instant eligibility, allowed provinces, and your 240-hour countdown.
        </p>
      </div>

      <div class="p-6 bg-paper-100 rounded-lg border border-paper-300">
        <div class="text-2xl mb-3">💳</div>
        <h3 class="font-display text-xl font-semibold mb-2">Payment Setup</h3>
        <p class="text-ink-light text-sm">
          WeChat Pay, Alipay, or tap-to-pay? A quick decision tree to get you paying like a local.
        </p>
      </div>

      <div class="p-6 bg-paper-100 rounded-lg border border-paper-300">
        <div class="text-2xl mb-3">📱</div>
        <h3 class="font-display text-xl font-semibold mb-2">Essential Apps</h3>
        <p class="text-ink-light text-sm">
          The 5 apps you actually need, plus eSIM setup so you're connected from touchdown.
        </p>
      </div>
    </div>
  </section>
</Layout>
