---
import Layout from '../../layouts/Layout.astro';
import { getTranslations } from '../../i18n/utils';
import type { Locale } from '../../i18n/translations';

const locale: Locale = 'ja';
const t = getTranslations(locale);
---

<Layout title={`${t.esim.title} — ChinaTransit`} description={t.meta.esimDescription} locale={locale}>
  <div class="max-w-reading mx-auto px-4 py-12">
    <div class="text-center mb-10">
      <p class="font-chinese text-ink-light text-sm mb-2">{t.esim.subtitleLocal}</p>
      <h1 class="font-display text-4xl font-bold text-ink">{t.esim.title}</h1>
      <p class="text-ink-light mt-2">{t.esim.subtitle}</p>
    </div>

    <div class="space-y-8">
      <div class="p-6 bg-paper-100 rounded-xl border border-paper-300">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-mineral/10 rounded-lg flex items-center justify-center text-mineral text-xl shrink-0">
            📶
          </div>
          <div>
            <h2 class="font-display text-2xl font-semibold mb-2">{t.esim.esimRecommended}</h2>
            <p class="text-ink-light text-sm mb-4">{t.esim.esimDesc}</p>
            <div class="space-y-3">
              <div class="p-3 bg-paper-50 rounded-lg border border-paper-300">
                <h3 class="font-semibold text-sm mb-1">{t.esim.airaloTitle}</h3>
                <p class="text-sm text-ink-light">{t.esim.airaloDesc}</p>
              </div>
              <div class="p-3 bg-paper-50 rounded-lg border border-paper-300">
                <h3 class="font-semibold text-sm mb-1">{t.esim.nomadTitle}</h3>
                <p class="text-sm text-ink-light">{t.esim.nomadDesc}</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="p-6 bg-paper-100 rounded-xl border border-paper-300">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-mineral/10 rounded-lg flex items-center justify-center text-mineral text-xl shrink-0">
            🏪
          </div>
          <div>
            <h2 class="font-display text-2xl font-semibold mb-2">{t.esim.airportSimTitle}</h2>
            <p class="text-ink-light text-sm mb-4">{t.esim.airportSimDesc}</p>
            <ul class="space-y-2 text-sm">
              {t.esim.airportSimPros.map((pro: string) => (
                <li class="flex gap-2">
                  <span class="text-jade shrink-0">✓</span>
                  <span>{pro}</span>
                </li>
              ))}
              {t.esim.airportSimCons.map((con: string) => (
                <li class="flex gap-2">
                  <span class="text-cinnabar shrink-0">✗</span>
                  <span>{con}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <div class="p-4 bg-amber/10 rounded-lg border border-amber">
        <h3 class="font-semibold text-sm mb-2">{t.esim.vpnTitle}</h3>
        <p class="text-sm text-ink-light" set:html={t.esim.vpnDesc} />
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b border-paper-300">
              <th class="text-left p-3 font-semibold">{t.esim.comparisonHeaders.feature}</th>
              <th class="text-center p-3 font-semibold">{t.esim.comparisonHeaders.esim}</th>
              <th class="text-center p-3 font-semibold">{t.esim.comparisonHeaders.airportSim}</th>
            </tr>
          </thead>
          <tbody>
            {t.esim.comparisonRows.map((row: { feature: string; esim: string; airportSim: string }) => (
              <tr class="border-b border-paper-200">
                <td class="p-3 text-ink-light">{row.feature}</td>
                <td class="p-3 text-center">{row.esim}</td>
                <td class="p-3 text-center">{row.airportSim}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>
